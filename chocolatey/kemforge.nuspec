<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>kemforge</id>
    <version>1.3.2</version>
    <title>KemForge</title>
    <authors>Daan Acohen</authors>
    <projectUrl>https://github.com/ConnectingApps/kemforge</projectUrl>
    <licenseUrl>https://github.com/ConnectingApps/kemforge/blob/main/LICENSE</licenseUrl>
    <tags>curl http https post-quantum cryptography pqc ml-kem kyber</tags>
    <summary>A curl-compatible CLI tool with built-in Post-Quantum Cryptography (PQC) support.</summary>
    <description>KemForge is a modern, curl-compatible CLI tool for making web requests, built from the ground up with Post-Quantum Cryptography (PQC) support. It is the security-first successor to curl, designed to address the primary threat of the modern era: quantum attacks. No dependency on system TLS libraries — PQC works out of the box on every platform.</description>
    <releaseNotes>https://github.com/ConnectingApps/kemforge/releases</releaseNotes>
    <packageSourceUrl>https://github.com/ConnectingApps/kemforge</packageSourceUrl>
  </metadata>
</package>

